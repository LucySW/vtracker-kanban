{
  "manifest_version": 3,
  "name": "AI Video Workflow Tracker",
  "version": "1.0.0",
  "description": "Tracks video generations from Kling AI and WaveSpeed",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://*.klingai.com/*",
    "*://*.kuaishou.com/*",
    "*://*.wavespeed.ai/*",
    "*://*.wavespeed.cn/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.klingai.com/*",
        "*://*.wavespeed.ai/*"
      ],
      "js": ["interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "*://*.klingai.com/*",
        "*://*.wavespeed.ai/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "AI Video Tracker"
  }
}
